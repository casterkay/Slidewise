# Supabase
SLIDEWISE_SUPABASE_URL=https://your-project.supabase.co
SLIDEWISE_SUPABASE_ANON_KEY=eyJ...
SLIDEWISE_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Storage bucket name for keyframe images
SLIDEWISE_STORAGE_BUCKET=keyframes

# Processing limits
SLIDEWISE_MAX_VIDEO_DURATION=7200
SLIDEWISE_MAX_UPLOAD_SIZE_MB=500
SLIDEWISE_TEMP_DIR=/tmp/slidewise
